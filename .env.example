# ComfyUI via Cloudflare Tunnel (dual GPU)
COMFYUI_GPU1=https://gpu0.jazzrelaxation.com
COMFYUI_GPU2=https://gpu1.jazzrelaxation.com

# Optional single-endpoint fallback
# COMFYUI_BASE_URL=https://gpu0.jazzrelaxation.com

# Security
JWT_SECRET=replace-with-random-64-hex
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

# App
PORT=8000

# Persist DB (recommended for Railway Volume)
# DB_PATH=/data/comfybot.db

# Persist uploaded input images (thumbnail source) on Railway Volume
# UPLOAD_DIR=/data/uploads

# Persist per-job workflow snapshots (download from job list)
# WORKFLOW_ARCHIVE_DIR=/data/workflows
