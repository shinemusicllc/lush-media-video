# ComfyUI via Cloudflare Tunnel (dual GPU)
COMFYUI_GPU1=https://gpu0.jazzrelaxation.com
COMFYUI_GPU2=https://gpu1.jazzrelaxation.com

# Optional single-endpoint fallback
# COMFYUI_BASE_URL=https://gpu0.jazzrelaxation.com

# Security
JWT_SECRET=replace-with-random-64-hex
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

# App
PORT=8000
PUBLIC_BASE_URL=https://video.jazzrelaxation.com

# Telegram bot (optional)
# TELEGRAM_BOT_TOKEN=123456:replace-me
# TELEGRAM_POLL_TIMEOUT_S=30
# TELEGRAM_POLL_INTERVAL_S=2

# Persist DB (recommended for Railway Volume)
# DB_PATH=/data/comfybot.db

# Persist uploaded input images (thumbnail source) on Railway Volume
# UPLOAD_DIR=/data/uploads

# Persist per-job workflow snapshots (download from job list)
# WORKFLOW_ARCHIVE_DIR=/data/workflows

# Persist pending Telegram uploads before they are fully paired/enqueued
# TELEGRAM_PENDING_DIR=/data/telegram_pending

# Optional: force a common persistent base path for DB/uploads/workflows
# PERSIST_BASE_DIR=/data
